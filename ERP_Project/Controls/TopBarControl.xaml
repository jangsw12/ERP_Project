<UserControl x:Class="ERP_Project.Controls.TopBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ERP_Project.Controls"
             xmlns:conv="clr-namespace:ERP_Project.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="60">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="#2C3E50"
            UseLayoutRounding="True"
            SnapsToDevicePixels="True">
        <Grid Margin="15 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!--좌측 로고-->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="ERP"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0 0 10 0"/>
                <TextBlock Text="Manufacturing System"
                           Foreground="#BDC3C7"
                           FontSize="13"
                           VerticalAlignment="Bottom"/>
            </StackPanel>

            <!--중앙 네비 버튼-->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                <Button Content="품목관리"
                        Width="100" Height="36"
                        Margin="5 0"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding ShowItemCommand}"/>

                <Button Content="발주관리"
                        Width="100" Height="36"
                        Margin="5 0"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding ShowPurchaseCommand}"/>

                <Button Content="생산관리"
                        Width="100" Height="36"
                        Margin="5 0"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding ShowProductionCommand}"/>

                <Button Content="수주관리"
                        Width="100" Height="36"
                        Margin="5 0"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding ShowSalesCommand}"/>

                <Button Content="재고조회"
                        Width="100" Height="36"
                        Margin="5 0"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding ShowInventoryCommand}"/>
            </StackPanel>

            <!--우측 검색 + 사용자-->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right">
                <TextBox Margin="0 0 10 0"
                         Height="34" Width="200"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="검색"
                        Width="60" Height="34"
                        Margin="0 0 15 0"
                        Command="{Binding SearchCommand}"/>

                <TextBlock Text="{Binding CurrentUserName}"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>