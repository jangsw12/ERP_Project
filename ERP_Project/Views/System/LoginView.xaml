<UserControl x:Class="ERP_Project.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ERP_Project.Views" 
             xmlns:controls="clr-namespace:ERP_Project.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#ecf0f1">
        <Border Width="350" Height="300"
                Background="White"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="20">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="ERP 로그인"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 20"/>

                <controls:TextBoxControl Text="{Binding UserId, UpdateSourceTrigger=PropertyChanged}"
                                         Height="35"
                                         Background="White"
                                         WaterMarkText="아이디를 입력하세요."
                                         WaterMarkTextColor="Red"
                                         Validating="False"/>

                <controls:PasswordBoxControl Password="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                             Height="35"
                                             Background="White"
                                             WaterMarkText="비밀번호를 입력하세요."
                                             WaterMarkTextColor="Red"/>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="Red"
                           FontSize="12"
                           Margin="0 5 0 0"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"/>

                <Button Content="로그인"
                        Height="35"
                        Margin="0 10 0 0"
                        IsDefault="True"
                        Command="{Binding LoginCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
