<UserControl x:Class="ERP_Project.Views.ChangePasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ERP_Project.Views" 
             xmlns:controls="clr-namespace:ERP_Project.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#ecf0f1">
    <Grid>
        <Border Width="350" Height="350"
                Background="White"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="20">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <TextBlock Text="비밀번호 변경"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 20"/>

                <!-- 현재 비밀번호 -->
                <controls:PasswordBoxControl
                    Password="{Binding CurrentPassword, UpdateSourceTrigger=PropertyChanged}"
                    Height="35"
                    Background="White"
                    WaterMarkText="현재 비밀번호"
                    WaterMarkTextColor="Gray"/>

                <!-- 새 비밀번호 -->
                <controls:PasswordBoxControl
                    Password="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}"
                    Height="35"
                    Margin="0 10 0 0"
                    Background="White"
                    WaterMarkText="새 비밀번호"
                    WaterMarkTextColor="Gray"/>

                <!-- 새 비밀번호 확인 -->
                <controls:PasswordBoxControl
                    Password="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}"
                    Height="35"
                    Margin="0 10 0 0"
                    Background="White"
                    WaterMarkText="새 비밀번호 확인"
                    WaterMarkTextColor="Gray"/>

                <!-- 상태 메시지 -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="Red"
                           FontSize="12"
                           Margin="0 10 0 0"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"/>

                <!-- 변경 버튼 -->
                <Button Content="비밀번호 변경"
                        Height="35"
                        Margin="0 15 0 0"
                        Command="{Binding ChangePasswordCommand}"/>
                
                <!--돌아가기 버튼-->

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
