<UserControl x:Class="ERP_Project.Views.InventoryAddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ERP_Project.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="root">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--입력-->
        <Border Grid.Row="0"
                Padding="15"
                Background="#ECF0F1"
                CornerRadius="4">
            <WrapPanel VerticalAlignment="Center">
                
                <!--품목-->
                <TextBlock Text="품목"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <ComboBox Width="150"
                          Margin="0 0 15 0"
                          ItemsSource="{Binding ItemsLookup}"
                          DisplayMemberPath="ItemName"
                          SelectedValuePath="ItemId"
                          SelectedValue="{Binding ItemId}"/>

                <!--창고-->
                <TextBlock Text="창고"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <ComboBox Width="120"
                          Margin="0 0 15 0"
                          ItemsSource="{Binding WarehousesLookup}"
                          DisplayMemberPath="WarehouseName"
                          SelectedValuePath="WarehouseId"
                          SelectedValue="{Binding WarehouseId}"/>

                <!--거래유형-->
                <TextBlock Text="거래유형"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <ComboBox Width="120"
                          Margin="0 0 15 0"
                          ItemsSource="{Binding TranTypes}"
                          SelectedItem="{Binding TranType}"/>

                <!--참조유형-->
                <TextBlock Text="참조유형"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <ComboBox Width="120"
                          Margin="0 0 15 0"
                          ItemsSource="{Binding RefTypes}"
                          SelectedItem="{Binding RefType}"/>

                <!--수량-->
                <TextBlock Text="수량"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <TextBox Width="120"
                         Margin="0 0 15 0"
                         Text="{Binding Qty}"/>

                <!--단가-->
                <TextBlock Text="단가"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <TextBox Width="120"
                         Margin="0 0 15 0"
                         Text="{Binding UnitCost}"
                         IsReadOnly="True"/>
                
                <!--등록일-->
                <TextBlock Text="등록일"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <DatePicker SelectedDate="{Binding TranDate}"
                            Width="120"/>
            </WrapPanel>
        </Border>

        <!--비고-->
        <Border Grid.Row="1"
                Margin="0 10 0 0"
                Padding="10"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="4">
            <StackPanel>
                <TextBlock Text="비고"
                           Margin="0 0 0 5"/>
                <TextBox Height="100"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Text="{Binding TranRemark}"/>
            </StackPanel>
        </Border>
        
        <!--버튼-->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 10 0 0">
            <Button Content="저장"
                    Width="80"
                    Margin="5"
                    Command="{Binding SaveCommand}"/>

            <Button Content="취소"
                    Width="80"
                    Margin="5"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
