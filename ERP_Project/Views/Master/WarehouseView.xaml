<UserControl x:Class="ERP_Project.Views.WarehouseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ERP_Project.Views"
             xmlns:cont="clr-namespace:ERP_Project.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <cont:PageNumberConverter x:Key="PageNumberConverter"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--Search-->
        <Border Grid.Row="0"
                Background="#ECF0F1"
                Padding="10"
                CornerRadius="4">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="창고명"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <TextBox Width="150"
                         Margin="0 0 15 0"
                         Text="{Binding SearchWarehouseName, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="지역"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <TextBox Width="150"
                         Margin="0 0 15 0"
                         Text="{Binding SearchLocation, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="조회"
                        Width="80"
                        Command="{Binding SearchCommand}"/>
            </StackPanel>
        </Border>

        <!--CRUD Buttons-->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 10 0 10">
            <Button Content="신규"
                    Width="80"
                    Margin="5 0"
                    Command="{Binding AddCommand}"/>
            <Button Content="저장"
                    Width="80"
                    Margin="5 0"
                    Command="{Binding SaveCommand}"/>
            <Button Content="삭제"
                    Width="80"
                    Margin="5 0"
                    Command="{Binding DeleteCommand}"/>
        </StackPanel>

        <!--DataGrid-->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Warehouses}"
                  SelectedItem="{Binding SelectedWarehouse}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  RowHeaderWidth="20">
            <DataGrid.Columns>
                <DataGridTextColumn Header="창고명"
                                    Binding="{Binding WarehouseName, UpdateSourceTrigger=PropertyChanged}"
                                    Width="120"/>
                <DataGridTextColumn Header="지역"
                                    Binding="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                                    Width="150"/>
                <DataGridCheckBoxColumn Header="사용"
                                        Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}"
                                        Width="80"/>
                <DataGridTextColumn Header="생성일"
                                    Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}"
                                    IsReadOnly="True"
                                    Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!--Paging Area-->
        <Grid Grid.Row="3"
              Margin="0 10 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!--TotalCount-->
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding TotalCount, StringFormat=총 {0}건}"
                       FontWeight="SemiBold"/>

            <!--Move Page-->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button Content="◀ 이전"
                        Width="80"
                        Margin="5 0"
                        Command="{Binding PrevPageCommand}"/>

                <TextBlock Margin="10 0"
                           VerticalAlignment="Center"
                           FontWeight="Bold">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource PageNumberConverter}" Mode="OneWay">
                            <Binding Path="PageNumber"/>
                            <Binding Path="TotalPages"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <Button Content="다음 ▶"
                        Width="80"
                        Margin="5 0"
                        Command="{Binding NextPageCommand}"/>
            </StackPanel>

            <!--Choose PageSize-->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <TextBlock Text="페이지크기"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <ComboBox Width="70"
                          ItemsSource="{Binding PageSizeOptions}"
                          SelectedItem="{Binding PageSize}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
