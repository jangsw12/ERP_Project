<UserControl x:Class="ERP_Project.Views.PurchaseOrderDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ERP_Project.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--Header / Master Info-->
        <Border Grid.Row="0"
                Background="#ECF0F1"
                Padding="10"
                CornerRadius="4">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="발주번호"
                           Margin="0 0 5 0"
                           VerticalAlignment="Center"/>
                <TextBox Text="{Binding SelectedPurchaseOrder.PurchaseNumber}"
                         Width="120"
                         IsReadOnly="True"
                         Margin="0 0 15 0"/>

                <TextBlock Text="거래처"
                           Margin="0 0 5 0"
                           VerticalAlignment="Center"/>
                <ComboBox Width="150"
                          ItemsSource="{Binding SuppliersLookup}"
                          DisplayMemberPath="CustomerName"
                          SelectedValuePath="CustomerId"
                          SelectedValue="{Binding SelectedPurchaseOrder.SupplierId, Mode=TwoWay}"
                          Margin="0 0 15 0"/>

                <TextBlock Text="창고"
                           Margin="0 0 5 0"
                           VerticalAlignment="Center"/>
                <ComboBox Width="150"
                          ItemsSource="{Binding WarehousesLookup}"
                          DisplayMemberPath="WarehouseName"
                          SelectedValuePath="WarehouseId"
                          SelectedValue="{Binding SelectedPurchaseOrder.WarehouseId, Mode=TwoWay}"
                          Margin="0 0 15 0"/>

                <TextBlock Text="주문일"
                           Margin="0 0 5 0"
                           VerticalAlignment="Center"/>
                <DatePicker SelectedDate="{Binding SelectedPurchaseOrder.OrderDate}"
                            Width="120"
                            IsEnabled="False"
                            Margin="0 0 15 0"/>

                <TextBlock Text="상태"
                           Margin="0 0 5 0"
                           VerticalAlignment="Center"/>
                <Border Width="80"
                        Height="24"
                        Background="White"
                        BorderBrush="#BFBFBF"
                        BorderThickness="1"
                        Margin="0 0 15 0"
                        VerticalAlignment="Center"
                        Padding="4, 2">
                    <TextBlock Text="{Binding SelectedPurchaseOrder.StatusText}"
                               VerticalAlignment="Center"/>
                </Border>
                

                <TextBlock Text="비고"
                           Margin="0 0 5 0"
                           VerticalAlignment="Center"/>
                <TextBox Text="{Binding SelectedPurchaseOrder.Remark}"
                         Width="300"
                         Margin="0 0 15 0"/>
            </StackPanel>
        </Border>
        
        <!--Detail Grid-->
        <DataGrid Grid.Row="1"
                  Margin="0 10 0 0"
                  ItemsSource="{Binding Details}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="품목코드"
                                    Binding="{Binding ItemCode}"
                                    Width="120"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="품목명"
                                    Binding="{Binding ItemName}"
                                    Width="150"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="수량"
                                    Binding="{Binding Qty, StringFormat=N4}"
                                    Width="100"/>
                <DataGridTextColumn Header="단가"
                                    Binding="{Binding UnitPrice, StringFormat=N2}"
                                    Width="100"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="총액"
                                    Binding="{Binding Amount, StringFormat=N2}"
                                    Width="100"
                                    IsReadOnly="True"/>
                <DataGridTextColumn Header="비고"
                                    Binding="{Binding Remark}"
                                    Width="250"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <!--Buttons-->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="확정"
                    Width="80"
                    Command="{Binding ConfirmCommand}"/>
            <Button Content="저장"
                    Width="80"
                    Command="{Binding SaveCommand}"/>
            <Button Content="닫기"
                    Width="80"
                    Command="{Binding CloseCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
    