<UserControl x:Class="ERP_Project.Views.PurchaseOrderAddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ERP_Project.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!--Master 입력-->
        <Border Grid.Row="0"
                Padding="15"
                Background="#ECF0F1"
                CornerRadius="4">
            <WrapPanel VerticalAlignment="Center">
                
                <!--거래처-->
                <TextBlock Text="거래처"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <ComboBox Width="150"
                          Margin="0 0 15 0"
                          ItemsSource="{Binding SuppliersLookup}"
                          DisplayMemberPath="CustomerName"
                          SelectedValuePath="CustomerId"
                          SelectedValue="{Binding Master.SupplierId, Mode=TwoWay}"/>

                <!--창고-->
                <TextBlock Text="창고"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <ComboBox Width="150"
                          Margin="0 0 15 0"
                          ItemsSource="{Binding WarehousesLookup}"
                          DisplayMemberPath="WarehouseName"
                          SelectedValuePath="WarehouseId"
                          SelectedValue="{Binding Master.WarehouseId, Mode=TwoWay}"/>

                <!--주문일-->
                <TextBlock Text="주문일"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <DatePicker SelectedDate="{Binding Master.OrderDate}"
                            Width="120"/>
              
                <!--상태-->
                <TextBlock Text="상태"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <ComboBox Width="120"
                          Margin="0 0 15 0"
                          ItemsSource="{Binding StatusList}"
                          SelectedIndex="{Binding Master.Status, Mode=TwoWay}"
                          SelectedValuePath=""
                          DisplayMemberPath="."/>

                <!--비고-->
                <TextBlock Text="비고"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <TextBox Width="200"
                         Text="{Binding Master.Remark}"/>
            </WrapPanel>
        </Border>
        
        <!--Detail Grid-->
        <Border Grid.Row="1"
                Margin="0 10 0 0"
                Padding="10"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="4">
            <StackPanel>
                <TextBlock Text="발주 상세"
                           Margin="0 0 0 5"/>
                <DataGrid x:Name="dataGrid"
                          ItemsSource="{Binding Details}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          Margin="0 5 0 0"
                          Height="250">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="품목"
                                                Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ItemName}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.ItemsLookup, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              SelectedValue="{Binding ItemId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="ItemId"
                                              DisplayMemberPath="ItemName"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="수량"
                                            Width="100"
                                            Binding="{Binding Qty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="단가"
                                            Width="100"
                                            Binding="{Binding UnitPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="금액"
                                            Width="120"
                                            Binding="{Binding Amount}"
                                            IsReadOnly="True"/>
                        <DataGridTextColumn Header="비고"
                                            Width="200"
                                            Binding="{Binding Remark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
        
        <!--버튼-->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 10 0 0">
            <Button Content="저장"
                    Width="80"
                    Margin="5"
                    Click="Save_Click"
                    Command="{Binding SaveCommand}"/>
            <Button Content="취소"
                    Width="80"
                    Margin="5"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
