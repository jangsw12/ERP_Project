<UserControl x:Class="ERP_Project.Views.ProductionOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ERP_Project.Views"
             xmlns:cont="clr-namespace:ERP_Project.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="root">
    <UserControl.Resources>
        <cont:PageNumberConverter x:Key="PageNumberConverter"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--Search-->
        <Border Grid.Row="0"
                Background="#ECF0F1"
                Padding="10"
                CornerRadius="4">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="완제품"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <ComboBox Width="150"
                          Margin="0 0 15 0"
                          ItemsSource="{Binding FinishedItemsLookup}"
                          SelectedValuePath="ItemId"
                          DisplayMemberPath="ItemName"
                          SelectedValue="{Binding SearchFinishedItemId}"/>

                <TextBlock Text="사용자재"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <ComboBox Width="150"
                          Margin="0 0 15 0"
                          ItemsSource="{Binding ComponentItemsLookup}"
                          SelectedValuePath="ItemId"
                          DisplayMemberPath="ItemName"
                          SelectedValue="{Binding SearchComponentItemId}"/>

                <TextBlock Text="생산번호"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <TextBox Width="150"
                         VerticalContentAlignment="Center"
                         Margin="0 0 15 0"
                         Text="{Binding SearchProductionNumber, UpdateSourceTrigger=PropertyChanged}"/>

                <!--BOM관리 이동 버튼-->
                <Button Content="BOM관리"
                        Width="80" Height="25"
                        Margin="0 0 15 0"
                        Command="{Binding GoBOMCommand}"/>

                <TextBlock Text="기간"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>

                <DatePicker SelectedDate="{Binding SearchDateFrom}"
                            Width="120"/>
                <TextBlock Text="~"
                           VerticalAlignment="Center"
                           Margin="0 5"/>
                <DatePicker SelectedDate="{Binding SearchDateTo}"
                            Width="120"
                            Margin="0 0 15 0"/>

                <Button Content="조회"
                        Width="80"
                        Command="{Binding SearchCommand}"/>
            </WrapPanel>
        </Border>

        <!--DataGrid-->
        <DataGrid Grid.Row="1"
                  Margin="0 10 0 0"
                  ItemsSource="{Binding ProductionOrders}"
                  SelectedItem="{Binding SelectedProductionOrder}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  RowHeaderWidth="20">
            <DataGrid.Columns>
                <DataGridTextColumn Header="생산번호"
                                    Binding="{Binding ProductionNumber}"
                                    Width="120"/>
                <DataGridTextColumn Header="(완제품)품목코드"
                                    Binding="{Binding ItemCode}"
                                    Width="120"/>
                <DataGridTextColumn Header="(완제품)품목명"
                                    Binding="{Binding ItemName}"
                                    Width="150"/>
                <DataGridTextColumn Header="(사용자재)품목코드"
                                    Binding="{Binding ComponentItemCode}"
                                    Width="120"/>
                <DataGridTextColumn Header="(사용자재)품목명"
                                    Binding="{Binding ComponentItemName}"
                                    Width="150"/>
                <DataGridTextColumn Header="자재 수량"
                                    Binding="{Binding RequiredQty, StringFormat=N4}"
                                    Width="100"/>
                <DataGridTextColumn Header="사용 자재 수량"
                                    Binding="{Binding UsedQty, StringFormat=N4}"
                                    Width="100"/>
                <DataGridTextColumn Header="생산 계획 수량"
                                    Binding="{Binding PlanQty, StringFormat=N4}"
                                    Width="100"/>
                <DataGridTextColumn Header="생산 완료 수량"
                                    Binding="{Binding ProducedQty, StringFormat=N4}"
                                    Width="100"/>
                <DataGridTextColumn Header="상태"
                                    Binding="{Binding Status}"
                                    Width="100"/>
                <DataGridTextColumn Header="시작일"
                                    Binding="{Binding StartDate, StringFormat=yyyy-MM-dd}"
                                    Width="120"/>
                <DataGridTextColumn Header="종료일"
                                    Binding="{Binding EndDate, StringFormat=yyyy-MM-dd}"
                                    Width="120"/>
                <DataGridTextColumn Header="등록일"
                                    Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}"
                                    Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!--Paging Area-->
        <Grid Grid.Row="2"
              Margin="0 10 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!--TotalCount-->
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Text="{Binding TotalCount, StringFormat=총 {0}건}"
                       FontWeight="SemiBold"/>

            <!--Move Page-->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button Content="◀ 이전"
                        Width="80"
                        Margin="5 0"
                        Command="{Binding PrevPageCommand}"/>

                <TextBlock Margin="10 0"
                           VerticalAlignment="Center"
                           FontWeight="Bold">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource PageNumberConverter}">
                            <Binding Path="PageNumber"/>
                            <Binding Path="TotalPages"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>

                <Button Content="다음 ▶"
                        Width="80"
                        Margin="5 0"
                        Command="{Binding NextPageCommand}"/>
            </StackPanel>

            <!--Choose PageSize-->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <TextBlock Text="페이지크기"
                           VerticalAlignment="Center"
                           Margin="0 0 5 0"/>
                <ComboBox Width="70"
                          ItemsSource="{Binding PageSizeOptions}"
                          SelectedItem="{Binding PageSize}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
